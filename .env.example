# Email Configuration
# Admin email (where booking notifications will be sent)
ADMIN_EMAIL=shishachauffeurs@gmail.com

# For Gmail, you'll need to:
# 1. Enable 2-factor authentication
# 2. Generate an app password: https://support.google.com/accounts/answer/185833
# 3. Use your Gmail and the app password below

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-sending-gmail@gmail.com
SMTP_PASS=your-16-character-gmail-app-password
EMAIL_FROM=your-sending-gmail@gmail.com
EMAIL_FROM_NAME="Shisha Chauffeurs"

# Alternative SMTP providers:
# For Outlook/Hotmail:
# SMTP_HOST=smtp-mail.outlook.com
# SMTP_PORT=587

# For Yahoo:
# SMTP_HOST=smtp.mail.yahoo.com
# SMTP_PORT=587

# For custom SMTP:
# SMTP_HOST=your-smtp-server.com
# SMTP_PORT=587
